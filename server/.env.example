# 🛰️ University Placement System - Server Environment Template
# Instructions: Copy this file to .env.production and populate with actual credentials.

# ⚙️ Server Configuration
PORT=5000
NODE_ENV=production

# 🔌 Database Configuration
# Primary MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/database_name

# 🔐 Authentication (JWT)
# Use a strong, random 64-character hex string
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# 🌍 Deployment & CORS
# Used to whitelist the frontend domain in production
FRONTEND_URL=https://uniplacements.vercel.app

# 🤖 AI & Machine Learning Services
# Required for core preparation and analysis features
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AFFINDA_API_KEY=aff_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 📧 Email Service (SMTP)
# Note: Google accounts require "App Passwords" for SMTP access
EMAIL_USER=notifications@yourdomain.com
EMAIL_PASS=your_smtp_app_password
ADMIN_EMAIL=admin@yourdomain.com

# 🧪 Demonstration & Testing
# Password for auto-generated test accounts
DEMO_PASSWORD=StrongDemoPassword123!

# 🛡️ SERVER SECURITY GUIDELINES
# - Use .env files only for LOCAL development.
# - Production secrets MUST be managed via provider UI (Vercel, AWS, etc).
# - NEVER hardcode sensitive strings in the codebase.
# - Periodically rotate JWT secrets and API keys.


