# 🌐 University Placement System - Environment Template
# Instructions: Copy this file to .env.production or .env.local and fill in your actual values.
# ⚠️ CAUTION: NEVER commit files containing actual secrets to version control!

# 🔌 Database Configuration
# Get your connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/database_name

# 🔐 Authentication (JWT)
# Use a strong, random 64-character hex string for JWT_SECRET
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# 🌍 Node Environment
NODE_ENV=production

# 🚀 Deployment URLs
# Local development tip: use http://localhost:5173 for FRONTEND_URL
FRONTEND_URL=https://uniplacements.vercel.app
VITE_API_URL=https://uniplacements.vercel.app/api

# 📧 Email Configuration (SMTP)
# Note: Use a Gmail "App Password" if using Google SMTP
EMAIL_USER=notifications@yourdomain.com
EMAIL_PASS=your_smtp_app_password
ADMIN_EMAIL=admin@yourdomain.com

# 🤖 AI & Machine Learning Services
# Required for interview preparation and resume parsing features
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AFFINDA_API_KEY=aff_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 🧪 Demonstration & Testing
# Password for auto-generated test accounts during seeding
DEMO_PASSWORD=StrongDemoPassword123!

# 🛡️ Security Best Practices
# 1. Use unique secrets for development and production.
# 2. Regularly rotate API keys and tokens.
# 3. Use Vercel Environment Variables for production deployments.

